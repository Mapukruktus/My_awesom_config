#theme and font
font-family = "JetBrainsMono Nerd Font"
font-size = 22
theme = Atom
fullscreen = true
#window
window-decoration = false
window-width = 999
window-height = 999
window-padding-x = 10
window-padding-y = 10 
#cursor
cursor-style-blink = false
cursor-opacity = 1.0
cursor-style = block

#blackground 
background-opacity = 1

mouse-hide-while-typing = true 
